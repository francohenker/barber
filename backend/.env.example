# ============================================================
# BARBERÍA BACKEND — Variables de Entorno
# Copiar a .env y completar los valores reales
# ============================================================

# ---- Servidor ----
PORT=3001
NODE_ENV=development

# ---- Base de Datos ----
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=barberia_user
DB_PASSWORD=barberia_pass
DB_NAME=barberia_db
# Para TypeORM en producción usar DATABASE_URL
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ---- JWT ----
JWT_SECRET=change_this_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_key_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ---- Google OAuth 2.0 ----
# Obtener en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ---- WhatsApp Business API (Meta) ----
# Obtener en: https://developers.facebook.com/apps
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=my_custom_verify_token_for_webhook
WHATSAPP_WEBHOOK_SECRET=your_app_secret_for_hmac_verification
WHATSAPP_API_VERSION=v20.0

# ---- Frontend ----
FRONTEND_URL=http://localhost:3000
